# Optional real OpenAI-compatible provider smoke tests.
# Copy this file to .env.local and fill in local secrets there.
# Never commit .env.local or real API keys.

PI_OPENAI_COMPATIBLE_SMOKE_ENABLED=true
PI_OPENAI_COMPATIBLE_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
PI_OPENAI_COMPATIBLE_API_KEY=replace-with-local-secret
PI_OPENAI_COMPATIBLE_MODEL=replace-with-model-id

# Optional: enables the real negative smoke test that intentionally calls the
# provider with a wrong API key and expects a 401/403 authentication error.
PI_OPENAI_COMPATIBLE_NEGATIVE_ENABLED=false
